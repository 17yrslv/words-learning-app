<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive data from cloud backup -->
        <exclude domain="sharedpref" path="app_prefs.xml" />
        <exclude domain="database" path="word_database" />
        <exclude domain="database" path="word_database-shm" />
        <exclude domain="database" path="word_database-wal" />
        
        <!-- Include only DataStore preferences (theme and language settings) -->
        <include domain="sharedpref" path="datastore" />
    </cloud-backup>
    
    <device-transfer>
        <!-- Exclude sensitive data from device transfer -->
        <exclude domain="sharedpref" path="app_prefs.xml" />
        <exclude domain="database" path="word_database" />
        <exclude domain="database" path="word_database-shm" />
        <exclude domain="database" path="word_database-wal" />
        
        <!-- Include only DataStore preferences -->
        <include domain="sharedpref" path="datastore" />
    </device-transfer>
</data-extraction-rules>
